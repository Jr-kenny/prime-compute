# Broker brain — any OpenAI-compatible endpoint (NVIDIA NIM, Kimchi, etc.)
# NVIDIA NIM:  base https://integrate.api.nvidia.com/v1, model e.g. meta/llama-3.3-70b-instruct
# Kimchi:      base https://llm.kimchi.dev/openai/v1, model e.g. kimi-k2.6
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=
LLM_MODEL=meta/llama-3.3-70b-instruct

# Arc testnet (pinned, public — see docs/superpowers/foundations-report.md)
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
